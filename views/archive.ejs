<%-include('partials/header')%>
<main>
    <header>
        <div class="logo"><img src="/photos/logo.png" alt="logo" width="130px"></div>
        <nav>
            <div class="div">
                <a href="/index">
                    <i class="fa-regular fa-comment"></i>
                    <p>Discussion</p>
                </a>
            </div>
            <div class="div">
                <a href="/archive" class="active">
                    <i class="fa-solid fa-box-archive"></i>
                    <p>Archives</p>
                </a>
            </div>
            <div class="div">
                <a href="/profil">
                    <i class="fa-solid fa-user-pen"></i>
                    <p>Profil</p>
                </a>
            </div>
            <div class="div">
                <a href="/logout">
                    <i class="fa-solid fa-right-from-bracket"></i>
                    <p>Déconnexion</p>
                </a>
            </div>
        </nav>
    </header>

    <section class="contents">
        <div class="center" id="center">
            <div class="top">
                <h1>Archives</h1>
                <div class="input">
                    <input type="text" placeholder="Rechercher un message...">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </div>
            </div>
            <div class="allchat">
                <h2>Tous les Messages</h2>
                <div class="boxs">
                    <% if (messages && messages.length > 0) { %>
                        <% messages.forEach(msg => { %>
                            <div class="box">
                                <div class="profil">
                                    <img src="" alt="<%= msg.username %>">
                                    <div class="nom">
                                        <p class="nom"><%= msg.username %></p>
                                        <p class="prenom"><small><%= new Date(msg.created_at).toLocaleString('fr-FR') %></small></p>
                                    </div>
                                </div>
                                <div class="right">
                                    <div class="date"><%= new Date(msg.created_at).toLocaleDateString('fr-FR') %></div>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <div class="box" style="text-align: center; padding: 2rem;">
                            <p>Aucun message archivé</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <div class="chat">
            <div class="header">
                <div class="left">
                    <img src="/photos/logoanim.png" alt="Archive">
                    <div class="text">
                        <p class="nom prenom">Historique des Messages</p>
                        <p class="status">Archive</p>
                    </div>
                </div>
            </div>
            <div class="message" id="message">
                <% if (messages && messages.length > 0) { %>
                    <% messages.forEach(msg => { %>
                        <div class="boxsms <%= msg.username === user.username ? 'sms-sent' : 'sms-received' %>">
                            <span class="sms-content"><strong><%= msg.username %>:</strong> <%= msg.content %></span>
                            <small class="sms-date"><%= new Date(msg.created_at).toLocaleString('fr-FR') %></small>
                        </div>
                    <% }); %>
                <% } else { %>
                    <div style="text-align: center; padding: 2rem; color: #999;">
                        <p>Aucun message à afficher</p>
                    </div>
                <% } %>
            </div>
        </div>
    </section>
</main>
<%-include('partials/footer')%>
