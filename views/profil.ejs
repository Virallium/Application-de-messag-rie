
<style>
    :root {
        --bg-color: #ffffff;
        --secondary-color: #3ab1fd;
        --txt-color: #000000;
        --txt-descr: #666666; /* Gris doux pour les descriptions */
        --bg-light: #f5f7f9;
        --border-color: #eeeeee;
        --shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
    }

    /* --- Styles Généraux & Layout --- */
    * {
        margin: 0;
        padding: 0;
        text-decoration: none;
        box-sizing: border-box;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    body, html {
        width: 100%;
        height: 100%;
        background-color: var(--bg-light);
    }

    .profile-section {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100%;
        min-height: 100vh;
        padding: 2rem;
        background: linear-gradient(135deg, #f5f7f9 0%, #e3f2fd 100%);
    }

    .profile-card {
        width: 100%;
        max-width: 700px;
        background: var(--bg-color);
        border-radius: 24px;
        box-shadow: var(--shadow);
        overflow: hidden;
        animation: fadeIn 0.6s ease-out;
    }

    @keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    form {
        padding: 2.5rem;
    }

    .profile-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .profile-header h1 {
        font-size: 24px;
        color: var(--txt-color);
        margin-bottom: 0.5rem;
    }

    .profile-header p {
        color: var(--txt-descr);
        font-size: 14px;
    }

    /* --- Section Photo --- */
    .photo-section {
        display: flex;
        flex-direction: column;
        align-items: center;
        margin-bottom: 2rem;
    }

    .profile-photo {
        position: relative;
        cursor: pointer;
        transition: transform 0.3s ease;
    }

    .profile-photo:hover {
        transform: scale(1.02);
    }

    .profile-photo img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid var(--secondary-color);
        padding: 3px;
        background: white;
    }

    .photo-overlay {
        position: absolute;
        bottom: 5px;
        right: 5px;
        background: var(--secondary-color);
        width: 35px;
        height: 35px;
        border-radius: 50%;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        border: 3px solid white;
        font-size: 14px;
    }

    .photo-input { display: none; }

    /* --- Grille du Formulaire --- */
    .form-grid {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .form-group label {
        font-size: 13px;
        font-weight: 600;
        color: var(--txt-descr);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .form-group label i {
        color: var(--secondary-color);
    }

    .input-wrapper input, 
    .input-wrapper select, 
    .input-wrapper textarea {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid var(--border-color);
        border-radius: 12px;
        background: var(--bg-light);
        font-size: 14px;
        outline: none;
        transition: all 0.3s ease;
    }

    .input-wrapper input:focus, 
    .input-wrapper select:focus, 
    .input-wrapper textarea:focus {
        border-color: var(--secondary-color);
        background: #fff;
        box-shadow: 0 0 0 4px rgba(58, 177, 253, 0.1);
    }

    /* --- Boutons d'action --- */
    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
    }

    .btn-save {
        flex: 2;
        background: var(--secondary-color);
        color: white;
        border: none;
        padding: 14px;
        border-radius: 12px;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.3s;
    }

    .btn-cancel {
        flex: 1;
        background: white;
        border: 1px solid var(--border-color);
        padding: 14px;
        border-radius: 12px;
        cursor: pointer;
        color: var(--txt-descr);
        transition: background 0.3s;
    }

    .btn-save:hover { opacity: 0.9; }
    .btn-cancel:hover { background: #f9f9f9; }

    /* Responsive */
    @media (max-width: 600px) {
        .form-row {
            grid-template-columns: 1fr;
        }
        .profile-section {
            padding: 1rem;
        }
    }

</style>

<section class="profile-section">        

        <% 
            // Préparation des données pour éviter les erreurs undefined
            let u = (typeof user !== 'undefined' && user) ? user : {};
            let photoUrl = u.photo || `https://ui-avatars.com/api/?background=3ab1fd&color=fff&size=130&rounded=true&bold=true&name=${u.nom ? u.nom.charAt(0) : 'U'}`;
        %>

        <form action="/profile/update" method="POST" enctype="multipart/form-data">
            <div class="profile-header">
                <h1>Mon Profil</h1>
                <p>Gérez vos informations personnelles</p>
            </div>
            <!-- Photo de profil -->
            <div class="photo-section">
                <label class="profile-photo" for="photoInput">
                    <img src="<%= photoUrl %>" alt="Photo de profil" id="profileImage">
                    <div class="photo-overlay">
                        <i class="fas fa-camera"></i>
                    </div>
                </label>
                <input type="file" id="photoInput" class="photo-input" accept="image/*" name="photo">
                <p style="margin-top: 12px; color: var(--txt-descr); font-size: 12px;">
                    <i class="fas fa-info-circle"></i> Cliquez sur la photo pour la modifier
                </p>
            </div>

            <div class="form-grid">
                <!-- Nom et Prénom -->
                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-user"></i> Nom</label>
                        <div class="input-wrapper">
                            <input type="text" name="nom" value="<%= u.nom || '' %>" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-user-friends"></i> Prénom(s)</label>
                        <div class="input-wrapper">
                            <input type="text" name="prenom" value="<%= u.prenom || '' %>">
                        </div>
                    </div>
                </div>

                <!-- Contact -->
                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-mobile-alt"></i> Téléphone</label>
                        <div class="input-wrapper">
                            <input type="tel" name="telephone" value="<%= u.telephone || '' %>" required>
                        </div>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-envelope"></i> Email</label>
                        <div class="input-wrapper">
                            <input type="email" name="email" value="<%= u.email || '' %>">
                        </div>
                    </div>
                </div>

                <!-- Infos Supp -->
                <div class="form-row">
                    <div class="form-group">
                        <label><i class="fas fa-calendar-alt"></i> Date de naissance</label>
                        <div class="input-wrapper">
                            <input type="date" name="date_naissance" value="<%= u.date_naissance || '' %>">
                        </div>
                    </div>
                    <div class="form-group">
                        <label><i class="fas fa-venus-mars"></i> Genre</label>
                        <div class="input-wrapper">
                            <select name="genre">
                                <option value="">Sélectionnez</option>
                                <option value="homme" <%= u.genre === 'homme' ? 'selected' : '' %>>Homme</option>
                                <option value="femme" <%= u.genre === 'femme' ? 'selected' : '' %>>Femme</option>
                                <option value="autre" <%= u.genre === 'autre' ? 'selected' : '' %>>Autre</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Bio -->
                <div class="form-group">
                    <label><i class="fas fa-info-circle"></i> Bio / À propos</label>
                    <div class="input-wrapper">
                        <textarea name="bio" rows="4"><%= u.bio || '' %></textarea>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-save">
                        <i class="fas fa-save"></i> Enregistrer
                    </button>
                    <button type="button" class="btn-cancel" onclick="window.history.back()">
                        Annuler
                    </button>
                </div>
            </div>
        </form>
    </div>
</section>

<script>
    // Aperçu de la photo en temps réel
    const photoInput = document.getElementById('photoInput');
    const profileImage = document.getElementById('profileImage');

    if (photoInput && profileImage) {
        photoInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = (e) => profileImage.src = e.target.result;
                reader.readAsDataURL(file);
            }
        });
    }
</script>

