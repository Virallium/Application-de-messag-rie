
 <%-include('partials/header')%>
    <main>
        <div class="loading">
            <div class="center">
                <img src="/photos/logoanim.png" alt="logo" width="300px">
            </div>
        </div>
        <header>
            <div class="logo"><img src="/photos/logo.png" alt="logo" width="130px"></div>
            <nav>
                <div class="div">
                    <a href="/index" class="active">
                        <i class="fa-regular fa-comment"></i>
                        <p>Discussion</p>
                    </a>
                </div>
                <div class="div">
                    <a href="/archive">
                        <i class="fa-solid fa-box-archive"></i>
                        <p>Archives</p>
                    </a>
                </div>
                <div class="div">
                    <a href="/profil">
                        <i class="fa-solid fa-user-pen"></i>
                        <p>Profil</p>
                    </a>
                </div>
                <div class="div">
                    <a href="/logout">
                        <i class="fa-solid fa-right-from-bracket"></i>
                        <p>Déconnexion</p>
                    </a>
                </div>
            </nav>
        </header>
        
        <section class="contents">
            <div class="center" id="center">
                <div class="top">
                    <div class="headertop" style="display: flex; justify-content: space-between; align-items: center;">
                        <h1>Chat</h1>
                    </div>
                    <div class="input">
                        <input type="text" placeholder="Rechercher un utilisateur">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </div>
                </div>
                <div class="enligne">
                    <h2>En ligne</h2>
                    <div class="box">
                        <% if (onlineUsers && onlineUsers.length > 0) { %>
                            <% onlineUsers.forEach(user => { %>
                                <div class="img">
                                    <img src="<%= user.photo || 'https://tse4.mm.bing.net/th/id/OIP.Yh_Zd0cdrtxGpEjqC0tq6QHaHa?r=0&rs=1&pid=ImgDetMain&o=7&rm=3' %>" alt="<%= user.username %>">
                                    <p><%= user.username %></p>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>Aucun utilisateur en ligne</p>
                        <% } %>
                    </div>
                </div>
                <div class="allchat">
                    <h2>Tous les chats</h2>
                    <div class="boxs">
                        <% if (onlineUsers && onlineUsers.length > 0) { %>
                            <% onlineUsers.forEach(user => { %>
                                <div class="box chat-box" onclick="selectChat('<%= user.username %>', '<%= user.photo %>')">
                                    <div class="profil">
                                        <img src="<%= user.photo || 'https://tse4.mm.bing.net/th/id/OIP.Yh_Zd0cdrtxGpEjqC0tq6QHaHa?r=0&rs=1&pid=ImgDetMain&o=7&rm=3' %>" alt="<%= user.username %>">
                                        <div class="nom">
                                            <p class="nom"><%= user.username %></p>
                                            <p class="prenom"><%= user.middlename || 'Pas de prénom' %></p>
                                        </div>
                                    </div>
                                    <div class="right">
                                        <div class="date"><%= new Date().toLocaleDateString('fr-FR') %></div>
                                        <div class="vu_ou_non">✓✓</div>
                                    </div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p>Aucun chat disponible</p>
                        <% } %>
                    </div>
                </div>
                <div class="contactbox">
                    <h2>Contact</h2>
                    <form action="">
                        <div class="input">
                            <input type="text" placeholder="Nom">
                        </div>
                        <div class="input">
                            <input type="text" placeholder="Prénom">
                        </div>
                        <div class="input">
                            <input type="text" placeholder="Numéro de téléphone">
                        </div>
                        <button type="submit">Ajouter</button>
                        <a href="" id="closeContactForm">Fermer</a>
                    </form>
                </div>
            </div>
            <div class="chat">
           
                <div class="header">
                    <div class="left">
                        
                            <button id="backToList" class="mobile-back-btn" style="border: none; padding:.5rem;"><i class="fa-solid fa-arrow-left"></i></button>
                            
                            <img id="chatUserPhoto" src="/photos/default.png" alt="">
                            <div class="text">
                                <p class="nom prenom" id="chatUserName">Discussion Générale</p>
                                <p class="status" id="chatUserStatus">Hors ligne</p>
                            </div>
                        </div>
                        <a href="tel:" id="chatUserPhone" class="telephone"><i class="fa-solid fa-phone-flip"></i></a>
                    </div>
                        <div class="message" id="message">
                            <p style="padding:20px; color:#999;">Sélectionnez un utilisateur pour voir la conversation.</p>
                        </div>
                        <form action="" method="post" id="formEnvoy" class="d-flex align-items-center gap-2 p-3" class="form_sms">
                            <input type="text" placeholder="Ecrire" required id="Message" class="form-control flex-grow-1 rounded-pill">
                            <button type="submit" class="btn btn-primary px-4 rounded-pill flex-shrink-0">Envoyer</button>
                            <button id="supprimer"><i class="fa-solid fa-trash"></i></button>
                        </form>
                        
            </div>
        </section>
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const supprimerBtn=document.querySelector('#supprimer')
        const close_contact_form=document.querySelector('#closeContactForm')
        const footernav=document.querySelector('header')
        const nouveau_contact_btn=document.querySelector('#aj_contact')
        const contact_form=document.querySelector('.contactbox')
        const form = document.querySelector('#formEnvoy');
        const messageInput = document.getElementById('Message');
        const bodychat = document.getElementById('message');
        const userNameDisplay = document.getElementById('chatUserName');
        const userPhoneDisplay = document.getElementById('chatUserPhone');
        const userPhotoDisplay = document.getElementById('chatUserPhoto');
        const userStatusDisplay = document.getElementById('chatUserStatus');
        let currentChatUser = null;
        let messagesCache = [];

        // Rejoindre la room personnelle après connexion
        socket.on('connect', () => {
            socket.emit('join', '<%= user.username %>');
        });

        // Récupérer la liste des utilisateurs en ligne une seule fois
        let onlineList = JSON.parse('<%- JSON.stringify(onlineUsers || []) %>');
        renderUserList(onlineList);

        function renderUserList(users) {
            onlineList = users;
            const onlineHtml = users.map(user => `
                <div class="img" onclick="selectChat('${user.username}', '${user.photo || 'https://tse4.mm.bing.net/th/id/OIP.Yh_Zd0cdrtxGpEjqC0tq6QHaHa?r=0&rs=1&pid=ImgDetMain&o=7&rm=3'}')">
                    <img src="${user.photo || 'https://tse4.mm.bing.net/th/id/OIP.Yh_Zd0cdrtxGpEjqC0tq6QHaHa?r=0&rs=1&pid=ImgDetMain&o=7&rm=3'}" alt="${user.username}">
                    <p>${user.username}</p>
                </div>
            `).join('');
            const onlineContainer = document.querySelector('.enligne .box');
            if (onlineContainer) onlineContainer.innerHTML = onlineHtml || '<p>Aucun utilisateur en ligne</p>';

            const chatsHtml = users.map(user => `
                <div class="box chat-box" onclick="selectChat('${user.username}', '${user.photo || 'https://tse4.mm.bing.net/th/id/OIP.Yh_Zd0cdrtxGpEjqC0tq6QHaHa?r=0&rs=1&pid=ImgDetMain&o=7&rm=3'}')">
                    <div class="profil">
                        <img src="${user.photo || 'https://tse4.mm.bing.net/th/id/OIP.Yh_Zd0cdrtxGpEjqC0tq6QHaHa?r=0&rs=1&pid=ImgDetMain&o=7&rm=3'}" alt="${user.username}">
                        <div class="nom">
                            <p class="nom">${user.username}</p>
                            <p class="prenom">${user.middlename || 'Pas de prénom'}</p>
                        </div>
                    </div>
                    <div class="right">
                        <div class="date">${new Date().toLocaleDateString('fr-FR')}</div>
                        <div class="vu_ou_non">✓✓</div>
                    </div>
                </div>
            `).join('');
            const chatList = document.querySelector('.allchat .boxs');
            if (chatList) chatList.innerHTML = chatsHtml || '<p>Aucun chat disponible</p>';
        }

        function renderMessages(messages) {
            bodychat.innerHTML = '';
            if (!messages.length) {
                bodychat.innerHTML = '<p style="padding: 20px; color: #999;">Aucun message dans cette conversation.</p>';
                return;
            }
            messages.forEach((data) => {
                const p = document.createElement('p');
                const message = document.createElement('span');
                const date = document.createElement('small');

                p.classList.add('boxsms');
                p.classList.add(data.username === '<%= user.username %>' ? 'sms-sent' : 'sms-received');
                message.classList.add('sms-content');
                date.classList.add('sms-date');

                message.innerHTML = `<strong>${data.username}:</strong> ${data.content}`;
                date.textContent = new Date(data.created_at).toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });

                p.appendChild(message);
                p.appendChild(date);
                bodychat.appendChild(p);
            });
            bodychat.scrollTop = bodychat.scrollHeight;
        }

        async function loadChatHistory(contact) {
            if (!contact) return;
            const response = await fetch(`/api/messages/${encodeURIComponent(contact)}`);
            if (!response.ok) {
                console.error('Erreur chargement chat', await response.text());
                return;
            }
            const messages = await response.json();
            messagesCache = messages;
            renderMessages(messages);
        }

        function selectChat(username, photo) {
            currentChatUser = username;
            userNameDisplay.textContent = username;
            userPhotoDisplay.src = photo;
            userPhoneDisplay.href = 'tel:+243';

            const isOnline = onlineList.some(u => u.username === username);
            userStatusDisplay.textContent = isOnline ? "En ligne" : "Hors ligne";
            userStatusDisplay.className = 'status ' + (isOnline ? 'online' : 'offline');

            if (window.innerWidth < 1000) {
                centerCol.style.display = 'none';
                chatCol.style.display = 'flex';
                footernav.classList.add('hide_header');
            }

            loadChatHistory(username);
        }

        socket.on('online-users', (users) => {
            // si les utilisateurs sont seulement des noms, reconstruire les objets basés sur l'existant
            const mappedUsers = users.map(username => {
                const existing = onlineList.find(u => u.username === username);
                return existing || { username, photo: 'https://tse4.mm.bing.net/th/id/OIP.Yh_Zd0cdrtxGpEjqC0tq6QHaHa?r=0&rs=1&pid=ImgDetMain&o=7&rm=3' };
            });
            renderUserList(mappedUsers);
        });

        socket.on('chat', (data) => {
            if (!currentChatUser) return;
            const me = '<%= user.username %>';
            const isMine = data.username === me;
            const isForCurrent = data.recipient === currentChatUser && isMine;
            const isFromCurrent = data.username === currentChatUser && data.recipient === me;
            if (isForCurrent || isFromCurrent) {
                messagesCache.push(data);
                renderMessages(messagesCache);
            }
        });

        // Fonction pour sélectionner un chat
        // 1. Sélectionne les éléments nécessaires
        const backBtn = document.getElementById('backToList');
        const centerCol = document.getElementById('center');
        const chatCol = document.querySelector('.chat');

    // 3. Ajoute l'événement pour le bouton retour
    if(backBtn) {
        backBtn.addEventListener('click', () => {
            centerCol.style.display = 'block'; // Réaffiche la liste
            chatCol.style.display = 'none';    // Cache le chat
            footernav.classList.remove('hide_header'); // Réaffiche le menu
        });
    }

        form.addEventListener('submit', (e) => {
            e.preventDefault();
            if (messageInput.value !== "" && currentChatUser) {
                const data = {
                    name: '<%= user.username %>',
                    recipient: currentChatUser,
                    message: messageInput.value,
                    date: new Date().toLocaleDateString(),
                    senderId: socket.id
                };
                socket.emit('chat', data);
                messageInput.value = "";
                messageInput.focus()
            } else if (!currentChatUser) {
                alert('Veuillez sélectionner un utilisateur pour chatter.');
            }
        });

    </script>
 <%-include('partials/footer')%>
 
