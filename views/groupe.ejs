     <link rel="stylesheet" href="/style/style.css">
    <link rel="stylesheet" href="/style/media.css">
    <link rel="stylesheet" href="/style/register.css">
 <%-include('partials/header')%>
    <main>
        </>
        <header>
            <div class="logo"><img src="/photos/logo.png" alt="logo" width="130px"></div>
            <nav>
                <div class="div">
                    <a href="/index">
                        <i class="fa-regular fa-comment"></i>
                        <p>Discussion</p>
                    </a>
                </div>
                <div class="div">
                    <a href="/archive">
                        <i class="fa-solid fa-box-archive"></i>
                        <p>Archives</p>
                    </a>
                </div>
                <div class="div">
                    <a href="/profil">
                        <i class="fa-solid fa-user-pen"></i>
                        <p>Profil</p>
                    </a>
                </div>
                <div class="div">
                    <a href="/groupe" class="active">
                        <i class="fa-solid fa-people-line"></i>
                        <p>Groupe</p>
                    </a>
                </div>
            </nav>
        </header>
        
        <section class="contents">
            <div class="center" id="center">
                <div class="top">
                    <h1>Groupe</h1>
                    <div class="top-actions" style="display:flex; align-items:center; gap:10px; flex-wrap:wrap; margin-bottom:10px;">
                        <button id="openCreateGroup" style="padding:10px 16px; border:none; background:#007bff; color:#fff; cursor:pointer; border-radius:6px;">Créer un groupe</button>
                        <div class="input" style="flex:1; min-width:220px;">
                            <input type="text" id="searchInput" placeholder="Rechercher un groupe...">
                            <i class="fa-solid fa-magnifying-glass"></i>
                        </div>
                    </div>
                </div>
                <div class="modal" id="createGroupModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:1000;">
                    <div class="modal-content" style="background:#fff; padding:24px; border-radius:12px; width:100%; max-width:420px; position:relative; box-shadow:0 12px 30px rgba(0,0,0,0.18);">
                        <button id="closeModal" type="button" style="position:absolute; top:12px; right:12px; background:none; border:none; font-size:18px; cursor:pointer;">✕</button>
                        <h2 style="margin-top:0;">Créer un groupe</h2>
                        <form id="createGroupForm">
                            <label for="groupName" style="display:block; margin-bottom:8px; font-weight:600;">Nom du groupe</label>
                            <input id="groupName" name="nom_groupe" type="text" placeholder="Ex: DevOps Engineers" required style="width:100%; padding:10px 12px; margin-bottom:16px; border:1px solid #ccc; border-radius:8px;">
                            <button type="submit" style="width:100%; padding:12px; border:none; background:#28a745; color:#fff; border-radius:8px; cursor:pointer;">Créer le groupe</button>
                        </form>
                        <p id="createGroupMessage" style="margin-top:14px; color:#333; display:none;"></p>
                    </div>
                </div>
                <div class="allchat">
                    <h2>Communautés</h2>
                    <div class="boxs" id="groupesContainer">
                        <p style="text-align: center; color: #999; padding: 20px;">Recherchez un groupe pour voir les résultats...</p>
                    </div>
                </div>
            </div>
            <div class="chat">
                <div class="header">
                    <div class="left">
                        <img src="" alt="">
                        <div class="text">
                            <p class="nom prenom"></p>
                            <p class="status"></p>
                        </div>
                    </div>
                    <a href="" class="telephone"><i class="fa-solid fa-phone-flip"></i></a>
                </div>
                <div class="message" id="message">
                    
                </div>
                <form action="" method="post" id="formEnvoy">
                    <input type="text" placeholder="Ecrire" required id="Message">
                    <button type="submit">Envoyer</button>
                </form>
            </div>
        </section>
    </main>
    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const form = document.querySelector('#formEnvoy');
        const messageInput = document.getElementById('Message');
        const bodychat = document.getElementById('message');
        const searchInput = document.getElementById('searchInput');
        const groupesContainer = document.getElementById('groupesContainer');
        const openCreateGroup = document.getElementById('openCreateGroup');
        const createGroupModal = document.getElementById('createGroupModal');
        const closeModal = document.getElementById('closeModal');
        const createGroupForm = document.getElementById('createGroupForm');
        const createGroupMessage = document.getElementById('createGroupMessage');

        // Ouvre le modal de création de groupe
        openCreateGroup.addEventListener('click', () => {
            createGroupMessage.style.display = 'none';
            createGroupForm.reset();
            createGroupModal.style.display = 'flex';
        });

        // Ferme le modal
        closeModal.addEventListener('click', () => {
            createGroupModal.style.display = 'none';
        });

        // Fermer le modal en cliquant en dehors de la zone de contenu
        createGroupModal.addEventListener('click', (e) => {
            if (e.target === createGroupModal) {
                createGroupModal.style.display = 'none';
            }
        });

        // Soumettre le formulaire de création de groupe
        createGroupForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const formData = new FormData(createGroupForm);
            const nomGroupe = formData.get('nom_groupe').trim();

            if (!nomGroupe) {
                createGroupMessage.textContent = 'Le nom du groupe est requis.';
                createGroupMessage.style.color = '#d9534f';
                createGroupMessage.style.display = 'block';
                return;
            }

            try {
                const response = await fetch('/groupe/create', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: new URLSearchParams({ nom_groupe: nomGroupe }),
                });

                const result = await response.json();
                if (!response.ok) {
                    createGroupMessage.textContent = result.error || 'Erreur lors de la création du groupe.';
                    createGroupMessage.style.color = '#d9534f';
                    createGroupMessage.style.display = 'block';
                    return;
                }

                createGroupMessage.textContent = 'Groupe créé avec succès !';
                createGroupMessage.style.color = '#28a745';
                createGroupMessage.style.display = 'block';
                createGroupForm.reset();

                setTimeout(() => {
                    createGroupModal.style.display = 'none';
                }, 800);
            } catch (error) {
                console.error('Erreur création groupe:', error);
                createGroupMessage.textContent = 'Impossible de créer le groupe.';
                createGroupMessage.style.color = '#d9534f';
                createGroupMessage.style.display = 'block';
            }
        });

        // Fonction de recherche
        async function searchGroups(query) {
            try {
                const response = await fetch(`/api/search-groups?q=${encodeURIComponent(query)}`);
                const groupes = await response.json();
                displayGroups(groupes);
            } catch (error) {
                console.error('Erreur lors de la recherche:', error);
            }
        }

        // Afficher les groupes
        function displayGroups(groupes) {
            if (groupes.length === 0) {
                groupesContainer.innerHTML = '<p>Aucun groupe trouvé</p>';
                return;
            }

            groupesContainer.innerHTML = groupes.map(groupe => `
                <div class="box groupe-item" data-groupe-id="${groupe.id}">
                    <div class="profil">
                        <div class="nom">
                            <p class="nom">${groupe.nom_groupe}</p>
                            <p class="prenom">${groupe.membres_groupe} membres</p>
                        </div>
                    </div>
                    <div class="right">
                        <button class="join-group-button" data-groupe-id="${groupe.id}" style="padding:8px 12px; border:none; background:#28a745; color:#fff; border-radius:6px; cursor:pointer;">Rejoindre</button>
                    </div>
                </div>
            `).join('');
        }

        async function joinGroup(groupeId) {
            try {
                const response = await fetch(`/api/groupe/join/${groupeId}`, {
                    method: 'POST',
                });
                const result = await response.json();
                if (!response.ok) {
                    return alert(result.error || 'Impossible de rejoindre le groupe.');
                }
                alert('Vous avez rejoint le groupe !');
                searchGroups(searchInput.value.trim());
            } catch (error) {
                console.error(error);
                alert('Erreur lors de la jonction du groupe.');
            }
        }

        // Événement de recherche au clic sur Enter
        searchInput.addEventListener('keypress', (e) => {
            if (e.key === 'Enter') {
                e.preventDefault();
                const query = searchInput.value.trim();
                if (query === '') {
                    // Si la recherche est vide, afficher le message d'accueil
                    groupesContainer.innerHTML = '<p style="text-align: center; color: #999; padding: 20px;">Recherchez un groupe pour voir les résultats...</p>';
                } else {
                    searchGroups(query);
                }
            }
        });

        // Ajouter un événement de clic sur les boutons Rejoindre
        document.addEventListener('click', (e) => {
            const joinButton = e.target.closest('.join-group-button');
            if (joinButton) {
                const groupeId = joinButton.getAttribute('data-groupe-id');
                joinGroup(groupeId);
                return;
            }

            const groupeItem = e.target.closest('.groupe-item');
            if (groupeItem) {
                const groupeId = groupeItem.getAttribute('data-groupe-id');
                console.log('Groupe sélectionné:', groupeId);
            }
        });

        // Charger la liste des groupes immédiatement
        searchGroups('');

        form.addEventListener('submit', (e) => {
            e.preventDefault();
            if ( messageInput.value !== "") {
                const data = {
                    message: messageInput.value,
                    date:new Date().toLocaleDateString()
                };
                socket.emit('chat', data);
                messageInput.value = "";
                messageInput.focus()
            }
        });
        
        socket.on('chat', (data) => {
            const p = document.createElement('p');
            p.classList.add('boxsms')
            p.innerHTML = `<span class="boxsms"><b>${data.date}</b>: ${data.message}</span>`;
            bodychat.appendChild(p);
            bodychat.scrollTop = bodychat.scrollHeight;
        });
    </script>
 <%-include('partials/footer')%>
 